# Gemini API
GEMINI_KEY=your-gemini-api-key

# Instagram Graph API (used when '📤 인스타 아카이브' button is pressed)
IG_TOKEN=your-long-lived-access-token
IG_USER_ID=your-instagram-business-account-id

# Telegram bot token (BotFather)
TG_TOKEN=123456789:ABC...

# Shared secret used as Telegram webhook secret_token
# (sent back to /tg in X-Telegram-Bot-Api-Secret-Token header for auth)
API_SECRET=generate-a-long-random-string-here

# Cloud Storage
GCS_BUCKET=concept-archive-cards-yourname
